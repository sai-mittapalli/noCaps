# Copy this file to .env and fill in your values

# Get this from Supabase → Settings → Database → Connection string (URI)
# Replace [YOUR-PASSWORD] with your Supabase project password
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Change this to a long random string in production
JWT_SECRET=nocaps-dev-secret-change-in-production

# LiveKit — get from cloud.livekit.io
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
